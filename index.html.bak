<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>FORGE — AI Celebrity Personal Trainer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: "#0a0a0a",
              carbon: "#111113",
              steel: "#1a1a1e",
              slate2: "#2a2a30",
              gold: "#d4af37",
              goldbright: "#f5cf5d",
              ember: "#ff6a1a",
              emberbright: "#ff8a3d",
            },
            fontFamily: {
              display: ["'Bebas Neue'", "Impact", "sans-serif"],
              sans: ["Inter", "system-ui", "sans-serif"],
            },
            boxShadow: {
              gold: "0 0 0 1px rgba(212,175,55,0.3), 0 12px 40px -12px rgba(212,175,55,0.35)",
              ember: "0 0 0 1px rgba(255,106,26,0.35), 0 12px 40px -12px rgba(255,106,26,0.45)",
            },
          },
        },
      };
    </script>
    <style>
      html, body, #root { background: #0a0a0a; color: #f5f5f5; }
      body { font-family: "Inter", system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      .display { font-family: "Bebas Neue", Impact, sans-serif; letter-spacing: 0.02em; }
      .noise { background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 3px 3px; }
      @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
      .shimmer { background: linear-gradient(90deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0.04) 100%); background-size: 200% 100%; animation: shimmer 1.4s linear infinite; }
      @keyframes pulse-gold { 0%,100% { box-shadow: 0 0 0 0 rgba(212,175,55,0.6); } 50% { box-shadow: 0 0 0 10px rgba(212,175,55,0); } }
      .pulse-gold { animation: pulse-gold 1.6s infinite; }
      input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
      input[type=number] { -moz-appearance: textfield; }
      .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
    <script>
      // window.storage shim over localStorage
      (function () {
        if (window.storage && typeof window.storage.getItem === "function") return;
        const ls = window.localStorage;
        window.storage = {
          getItem: (k) => ls.getItem(k),
          setItem: (k, v) => ls.setItem(k, v),
          removeItem: (k) => ls.removeItem(k),
          keys: () => {
            const out = [];
            for (let i = 0; i < ls.length; i++) out.push(ls.key(i));
            return out;
          },
        };
      })();
    </script>
  </head>
